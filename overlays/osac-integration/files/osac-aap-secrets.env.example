# Sensitive credentials for the cluster-fulfillment-ig Secret.
# Copy this file to osac-aap-secrets.env and fill in your values.
# These values are applied to the cluster by scripts/aap-configuration.sh.
#
# Values must be plaintext — the script base64-encodes them automatically.
# DO NOT commit osac-aap-secrets.env to git.

# Netris API password
NETRIS_PASSWORD=

# SSH private keys — place as regular key files in this directory:
#   files/server-ssh-key          (private key for bare-metal servers)
#   files/server-ssh-bastion-key  (private key for the bastion host)
# The script reads and base64-encodes them automatically.

# AWS credentials for Route53 DNS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OpenStack credentials for cluster provisioning
OS_APPLICATION_CREDENTIAL_ID=
OS_APPLICATION_CREDENTIAL_SECRET=
OS_AUTH_TYPE=
OS_AUTH_URL=
